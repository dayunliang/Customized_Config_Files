#!/bin/sh
# ============================================================================
# 脚本名称：docker_alpine.sh (Ultimate UI/UX Pixel-Perfect Edition)
# 功能：Alpine Linux Docker 基础环境部署与钉钉监控自动化配置
# 优化重点：引入动态列宽补白算法，解决中英混合文本对齐痛点，实现终端像素级对齐
# ============================================================================

set -e

# ----------------------------------------------------------------------------
# 终端色彩与视觉组件定义
# ----------------------------------------------------------------------------
GREEN='\033[32m'; RED='\033[31m'; YELLOW='\033[33m'; BLUE='\033[34m'; PURPLE='\033[35m'; NC='\033[0m'
BOLD='\033[1m'

ok()    { printf "${GREEN}  ✔  ${NC}%s\n" "$*"; }
warn()  { printf "${YELLOW}  ▲  ${NC}%s\n" "$*"; }
err()   { printf "${RED}  ✘  ${NC}%s\n" "$*"; }
info()  { printf "${BLUE}  ▶  ${NC}%s\n" "$*"; }
title() { printf "\n${BOLD}${PURPLE}======================================================================${NC}\n${BOLD} 🚀  %s${NC}\n${BOLD}${PURPLE}======================================================================${NC}\n" "$*"; }

# ----------------------------------------------------------------------------
# Docker Runtime (运行时) 自愈模块
# ----------------------------------------------------------------------------
ensure_docker_runtime_ready() {
  set +e
  REPORT="/root/docker_runtime_fix_$(date +%Y%m%d_%H%M%S).log"
  touch "$REPORT"

  wait_sock() {
    N="${1:-15}"; i=0
    while [ $i -lt $N ]; do
      [ -S /var/run/docker.sock ] && return 0
      i=$((i+1)); sleep 1
    done
    return 1
  }

  restart_daemons() {
    rc-service docker stop >/dev/null 2>&1 || true
    rc-service containerd stop >/dev/null 2>&1 || true
    rm -rf /run/containerd/io.containerd.runtime.v2.task/moby/* >/dev/null 2>&1 || true
    rc-service containerd start >/dev/null 2>&1 || true
    rc-service docker start >/dev/null 2>&1 || true
    wait_sock 15 || return 1
    return 0
  }

  docker_info_brief() {
    docker info 2>/dev/null | awk '/Server Version|Default Runtime|Storage Driver|Backing Filesystem|Cgroup Version/ {print "     " $0}'
  }

  info "正在检测并补充运行时依赖 (jq, libseccomp)..."
  apk add --no-cache jq libseccomp >/dev/null 2>&1 || true

  info "正在初始化内核模块、Cgroup v2 架构与网络桥接链..."
  modprobe overlay 2>/dev/null || true
  modprobe br_netfilter 2>/dev/null || true
  mkdir -p /sys/fs/cgroup
  mount | grep -q "type cgroup2" || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
  rc-update add cgroups default >/dev/null 2>&1 || true
  rc-service cgroups start >/dev/null 2>&1 || true
  sysctl -w net.bridge.bridge-nf-call-iptables=1 >/dev/null 2>&1 || true
  sysctl -w net.bridge.bridge-nf-call-ip6tables=1 >/dev/null 2>&1 || true

  info "正在规范化配置 /etc/docker/daemon.json 引擎定义..."
  mkdir -p /etc/docker
  [ -s /etc/docker/daemon.json ] || echo '{}' > /etc/docker/daemon.json
  cp /etc/docker/daemon.json /etc/docker/daemon.json.bak.$(date +%Y%m%d%H%M%S)
  jq 'del(.runtimes) | ."default-runtime"="io.containerd.runc.v2"' /etc/docker/daemon.json > /etc/docker/daemon.json.new && mv /etc/docker/daemon.json.new /etc/docker/daemon.json
  ok "Engine 配置文件清理完成"

  info "正在唤醒 Docker 守护进程并验证套接字状态..."
  if restart_daemons; then
    ok "Docker 引擎套接字响应成功"
  else
    err "Docker 套接字激活超时，错误日志已导出至 $REPORT"
    tail -n 100 /var/log/docker.log >> "$REPORT" 2>&1
    tail -n 100 /var/log/containerd.log >> "$REPORT" 2>&1
  fi

  info "当前引擎核心拓扑参数："
  docker_info_brief || true

  info "[阶段 A] 验证原生 io.containerd.runc.v2 容器创建生态..."
  if docker run --rm hello-world >/dev/null 2>&1; then
    ok "原生 runc v2 沙箱拉起测试通过"
    PASSED=1
  else
    warn "阶段 A 异常，尝试修复 runc 运行库环境 (进入阶段 B)..."
    PASSED=0
  fi

  if [ "$PASSED" -eq 0 ]; then
    RUNC_OK=1
    if [ -x /usr/bin/runc ]; then /usr/bin/runc --version >/dev/null 2>&1 || RUNC_OK=0; else RUNC_OK=0; fi
    if [ "$RUNC_OK" -eq 0 ]; then
      warn "检测到底层 runc 释出异常，正在强制重载底层安全依赖..."
      apk add --no-cache libseccomp >/dev/null 2>&1 || true
    fi
    restart_daemons || true
    if docker run --rm hello-world >/dev/null 2>&1; then
      ok "修复后 runc v2 沙箱拉起测试通过"
      PASSED=1
    else
      warn "阶段 B 依然受阻，启动终极自愈预案：切换 crun 轻量级引擎 (进入阶段 C)..."
    fi
  fi

  if [ "$PASSED" -eq 0 ]; then
    info "正在拉取 crun 核心包并改写默认 Container Runtime 映射..."
    apk add --no-cache crun >/dev/null 2>&1 || true
    jq '."default-runtime"="crun" | .runtimes = (.runtimes // {}) | .runtimes.crun.path="/usr/bin/crun"' /etc/docker/daemon.json > /etc/docker/daemon.json.new && mv /etc/docker/daemon.json.new /etc/docker/daemon.json
    restart_daemons || true
    if docker run --rm hello-world >/dev/null 2>&1; then
      ok "终极自愈成功：已无缝平替至 crun 容器环境"
      PASSED=2
    else
      err "基础架构受损严重，所有 Runtime 均无法运行。请通过技术分析日志排查: $REPORT"
      tail -n 100 /var/log/docker.log >> "$REPORT" 2>&1
    fi
  fi

  echo "" >> "$REPORT"
  docker info >> "$REPORT" 2>&1 || true
  echo ""
  if [ "$PASSED" -eq 1 ]; then
    ok "状态汇总：核心架构运行在默认 io.containerd.runc.v2 状态下"
  elif [ "$PASSED" -eq 2 ]; then
    ok "状态汇总：系统处于 crun 兼容性自愈接管状态"
  else
    err "状态汇总：初始化自愈失败，存在致命阻塞"
  fi
  set -e
}

# ============================================================================
# 主脚本业务流水线
# ============================================================================

title "01. 运行权限鉴别"
if [ "$(id -u)" != "0" ]; then
  err "错误：本脚本包含系统级操作，请切换至 root 用户或使用 sudo 重新挂载执行！"
  echo ""; exit 1
fi
ok "用户身份确认：当前已具备完整系统操作权限"

title "02. Alpine APK 软件源优化 (中科大 USTC 镜像)"
if ! grep -q ustc /etc/apk/repositories 2>/dev/null; then
  info "正在将默认上游源重定向至中科大高带宽加速镜像..."
  tee /etc/apk/repositories <<-'EOF'
https://mirrors.ustc.edu.cn/alpine/latest-stable/main
https://mirrors.ustc.edu.cn/alpine/latest-stable/community
EOF
  info "同步远端镜像仓库索引中..."
  apk update
else
  ok "系统当前已锁定中科大加速软件源，自动保持现状（保障幂等）"
fi

title "03. 集中构建系统基础运维工具链包"
info "正在并行拉取并配置核心工具包、网络诊断组件及虚拟化 Guest 插件..."
apk add --no-cache \
  docker containerd runc openrc iptables ip6tables jq curl bash vim htop ca-certificates \
  git open-vm-tools open-vm-tools-guestinfo open-vm-tools-deploypkg \
  musl-locales musl-locales-lang less net-tools c-ares nftables \
  >/dev/null 2>&1 || true
ok "所有依赖底层扩展包及辅助组件部署完毕"

title "04. 系统多语言本地化与 Vim 编码环境清洗"
info "配置系统全局语言标准为 zh_CN.UTF-8 格式，防止日志乱码..."
cat >/etc/profile.d/locale.sh <<'EOF'
export LANG=zh_CN.UTF-8
export LC_CTYPE=zh_CN.UTF-8
export LC_ALL=zh_CN.UTF-8
EOF
chmod +x /etc/profile.d/locale.sh
. /etc/profile.d/locale.sh

info "正在向 Vim 全局配置中写入 UTF-8 文件字符集映射..."
mkdir -p /etc/vim
cat >/etc/vim/vimrc <<'EOF'
set encoding=utf-8
set termencoding=utf-8
set fileencoding=utf-8
set fileencodings=ucs-bom,utf-8,default,latin1
EOF
ok "系统语言环境与文本查看编码美化治理完成"

title "05. 系统级核心守护进程开机行为锁固"
info "向 OpenRC 系统管理器注册各服务运行级别控制点..."
rc-update add containerd default >/dev/null 2>&1 || true
rc-update add docker default >/dev/null 2>&1 || true
rc-update add cgroups default >/dev/null 2>&1 || true
rc-update add open-vm-tools boot >/dev/null 2>&1 || true
ok "已成功固化 containerd/docker/cgroups/open-vm-tools 开机自启属性"

title "06. Docker 引擎生产级配置调优与国内加速镜像注入"
info "正在注入多路高可用国内容器加速镜像源，并配置文件截断限制以防占满磁盘..."
mkdir -p /etc/docker
[ -f /etc/docker/daemon.json ] || echo '{}' > /etc/docker/daemon.json
cp /etc/docker/daemon.json /etc/docker/daemon.json.bak.$(date +%Y%m%d%H%M%S)

cat >/tmp/daemon.patch.json <<'JSON'
{
  "registry-mirrors": [
    "https://docker.m.daocloud.io",
    "https://dockerproxy.com",
    "https://mirror.baidubce.com",
    "https://docker.nju.edu.cn",
    "https://docker.mirrors.sjtu.edu.cn",
    "https://mirror.iscas.ac.cn"
  ],
  "log-driver": "json-file",
  "log-opts": { "max-size": "10m", "max-file": "3" },
  "iptables": true,
  "default-runtime": "io.containerd.runc.v2"
}
JSON
jq -s '.[0] * .[1]' /etc/docker/daemon.json /tmp/daemon.patch.json > /etc/docker/daemon.json.new
mv /etc/docker/daemon.json.new /etc/docker/daemon.json
rm -f /tmp/daemon.patch.json
ok "容器加速镜像与磁盘守护限制规则合并生成完毕"

title "07. Containerd 底层容器隔离运行时行为调优"
info "正在校验并重写 /etc/containerd/config.toml 标准配置文件..."
if [ ! -s /etc/containerd/config.toml ]; then
  containerd config default >/etc/containerd/config.toml
fi
sed -i -E 's#(^\s*default_runtime_name\s*=\s*).*$#\1"runc"#' /etc/containerd/config.toml || true
ok "containerd 核心配置文件重塑锁定完成"

title "08. 激活 Linux 内核 Bridge 流量网桥链与 Cgroup2 挂载"
info "正在动态注入内核模块参数，打通容器虚拟化网桥网络转发..."
modprobe br_netfilter 2>/dev/null || true
modprobe overlay 2>/dev/null || true
mkdir -p /etc/sysctl.d
tee /etc/sysctl.d/99-docker-bridge.conf >/dev/null <<'SYS'
net.bridge.bridge-nf-call-iptables=1
net.bridge.bridge-nf-call-ip6tables=1
SYS
sysctl -w net.bridge.bridge-nf-call-iptables=1 >/dev/null 2>&1 || true
sysctl -w net.bridge.bridge-nf-call-ip6tables=1 >/dev/null 2>&1 || true
mkdir -p /sys/fs/cgroup
mount | grep -q "type cgroup2" || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
ok "系统内核流量转发连通性参数更新完毕"

title "09. 优雅热重启后台各核心控制层进程"
info "正在执行基础架构服务的干净重启流程，刷新全局配置文件状态..."
rc-service open-vm-tools start >/dev/null 2>&1 || true
rc-service docker stop >/dev/null 2>&1 || true
rc-service containerd stop >/dev/null 2>&1 || true
rm -rf /run/containerd/io.containerd.runtime.v2.task/moby/* 2>/dev/null || true
rc-service containerd start >/dev/null 2>&1 || true
rc-service docker start >/dev/null 2>&1 || true
ok "系统后台进程热重载完成，当前运行状态平稳"

title "10. 部署多重云编排工具 Docker Compose"
info "正在扫描本地环境以确定最优的 Compose 环境配比..."
if command -v docker-compose >/dev/null 2>&1; then
  ok "系统中已留存原生传统的 docker-compose (v1)"
else
  if ! docker compose version >/dev/null 2>&1; then
    info "尝试通过官方仓库索引部署高级 Compose v2 (docker-cli-compose)..."
    if apk add --no-cache docker-cli-compose >/dev/null 2>&1; then
      ok "容器标准编排扩展 Compose v2 插件安装完成"
    else
      warn "APK 安装发生阻碍，正在启动外部 GitHub 动态编译包拉取方案..."
      DOCKER_COMPOSE_VERSION="$(curl -s https://api.github.com/repos/docker/compose/releases/latest | grep tag_name | cut -d '"' -f4 || true)"
      [ -z "$DOCKER_COMPOSE_VERSION" ] && DOCKER_COMPOSE_VERSION="1.29.2"
      curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
      chmod +x /usr/local/bin/docker-compose
      ok "外部源重载部署完成，当前版本为: docker-compose ${DOCKER_COMPOSE_VERSION}"
    fi
  else
    ok "系统已集成最新的原生命令式 Docker Compose v2 生态"
  fi
fi

title "11. 交互式部署私有仓磁盘监控脚本 (钉钉通知服务)"
REPO_PRIVATE_TMP="/root/.private_config_repo_tmp"
TARGET_BIN_PATH="/usr/bin/disk_space_check.dingtalk"
FILE_NAME="disk_space_check.dingtalk"

SSH_KEY_FOUND=0
PUB_KEY_PATH=""
for KEY_TYPE in "id_ed25519.pub" "id_rsa.pub"; do
    if [ -f "$HOME/.ssh/$KEY_TYPE" ]; then
        SSH_KEY_FOUND=1; PUB_KEY_PATH="$HOME/.ssh/$KEY_TYPE"; break
    fi
done

if [ "$SSH_KEY_FOUND" -eq 0 ]; then
    warn "本地未寻获有效 SSH 公钥，系统正在自动计算并签发一组高等级 Ed25519 秘钥对..."
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    ssh-keygen -t ed25519 -C "cron@homelab.local" -N "" -f "$HOME/.ssh/id_ed25519"
    PUB_KEY_PATH="$HOME/.ssh/id_ed25519.pub"
    ok "公私钥对本地计算生成完毕"
fi

# 控制台信息盒 (Box Layout)
printf "${BLUE}┌──────────────────────────────────────────────────────────────────────────┐${NC}\n"
printf "${BLUE}│${YELLOW}  📢 秘钥绑定权限引导提示                                                 ${BLUE}│${NC}\n"
printf "${BLUE}├──────────────────────────────────────────────────────────────────────────┤${NC}\n"
printf "${BLUE}│${NC}  请将下方高亮的 SSH 公钥内容复制并妥善绑定至您的 GitHub 账户中。         ${BLUE}│${NC}\n"
printf "${BLUE}│${NC}  必须确保此 Key 拥有私有配置项目 [private_config] 的读取（Read）权限。  ${BLUE}│${NC}\n"
printf "${BLUE}│${NC}  绑定入口: GitHub ──> Settings ──> SSH and GPG keys ──> New SSH key        ${BLUE}│${NC}\n"
printf "${BLUE}└──────────────────────────────────────────────────────────────────────────┘${NC}\n\n"
printf "${BOLD}${GREEN}"
cat "$PUB_KEY_PATH"
printf "${NC}\n"
printf "${BLUE}────────────────────────────────────────────────────────────────────────────${NC}\n"
printf "${BOLD}${YELLOW}  ❯ 请在 GitHub 完成公钥权限绑定后，按 [回车键] 推进部署: ${NC}"
read CONFIRM_SSH
printf "${BLUE}────────────────────────────────────────────────────────────────────────────${NC}\n\n"

rm -rf "$REPO_PRIVATE_TMP"
info "正在启动稀疏克隆（Sparse Checkout）模式按需拉取磁盘监控核心脚本..."
git clone --filter=blob:none --no-checkout git@github.com:dayunliang/private_config.git "$REPO_PRIVATE_TMP"
cd "$REPO_PRIVATE_TMP" || exit 1
git sparse-checkout init --no-cone
git sparse-checkout set "$FILE_NAME"
git checkout main || true
cd /root

if [ -f "$REPO_PRIVATE_TMP/$FILE_NAME" ]; then
    rm -f "$TARGET_BIN_PATH"
    mv "$REPO_PRIVATE_TMP/$FILE_NAME" "$TARGET_BIN_PATH"
    chmod +x "$TARGET_BIN_PATH"
    rm -rf "$REPO_PRIVATE_TMP"
    ok "钉钉磁盘监控服务文件已下发至 $TARGET_BIN_PATH 并赋予执行权限"
    
    # 定时配置仪表盘 (Dashboard Menu)
    printf "\n${BLUE}┌──────────────────────────────────────────────────────────────────────────┐${NC}\n"
    printf "${BLUE}│${BOLD} ⏰ 请为系统磁盘监控脚本指定合理的调度频率计划                            ${BLUE}│${NC}\n"
    printf "${BLUE}├──────────────────────────────────────────────────────────────────────────┤${NC}\n"
    printf "${BLUE}│${NC}   【1】每小时 执行一次            (0 * * * *)                            ${BLUE}│${NC}\n"
    printf "${BLUE}│${NC}   【2】每 6 小时 执行一次         (0 */6 * * *)   --> [系统默认推荐]     ${BLUE}│${NC}\n"
    printf "${BLUE}│${NC}   【3】每天凌晨 2:00 执行一次     (0 2 * * *)                            ${BLUE}│${NC}\n"
    printf "${BLUE}│${NC}   【4】手动填入 5 位标准 Cron 表达式                                      ${BLUE}│${NC}\n"
    printf "${BLUE}└──────────────────────────────────────────────────────────────────────────┘${NC}\n"
    printf "${BOLD}${YELLOW}  ❯ 请键入您的选择编号 [1-4] (留空默认选择2): ${NC}"
    read CRON_CHOICE

    case "$CRON_CHOICE" in
        1) CRON_TIME="0 * * * *" ;;
        2) CRON_TIME="0 */6 * * *" ;;
        3) CRON_TIME="0 2 * * *" ;;
        4)
            printf "\n${BOLD}${YELLOW}  ❯ 请输入您合法的自定义 Cron 表达式 (例如 '0 */3 * * *'): ${NC}"
            read CUSTOM_CRON
            CRON_TIME=${CUSTOM_CRON:-"0 */6 * * *"}
            ;;
        *) CRON_TIME="0 */6 * * *" ;;
    esac

    CRON_JOB_DISK="$CRON_TIME $TARGET_BIN_PATH >> /var/log/disk_space_check.log 2>&1"
    (crontab -l 2>/dev/null | grep -v "$FILE_NAME"; echo "$CRON_JOB_DISK") | crontab -
    ok "系统计划任务管理层注册成功！当前执行频率被锁定为: [$CRON_TIME]"
else
    rm -rf "$REPO_PRIVATE_TMP"
    err "致命错误：未能从私有库提取到 $FILE_NAME 核心程序，自动越过计划任务编排步骤"
fi

title "12. 触发引擎环境深度自愈检测与二次纠错"
ensure_docker_runtime_ready

title "13. 全大盘运行指标自动化收敛盘点"
REPORT_SUM="/root/docker_env_report_$(date +%Y%m%d_%H%M%S).txt"
PASS=1
echo "=========================================" > "$REPORT_SUM"
echo "  Docker Environment Self-Check Report   " >> "$REPORT_SUM"
echo "  Time: $(date)                          " >> "$REPORT_SUM"
echo "=========================================" >> "$REPORT_SUM"

# ============================================================================
# 极客高精对齐检测小工具（核心修改点）
# ============================================================================
check() {
  DESC="$1"; CMD="$2"
  
  # 1. 动态逆向计算中英混合文本在终端显示的实际“视觉列宽”
  BYTES=$(printf "%s" "$DESC" | wc -c)
  CHARS=$(printf "%s" "$DESC" | wc -m)
  VISUAL_WIDTH=$(( (BYTES + CHARS) / 2 ))
  
  # 2. 设定大盘文本对齐基准线（50列宽），计算当前行需要精确补多少空格
  TARGET_LINE_WIDTH=50
  if [ $VISUAL_WIDTH -lt $TARGET_LINE_WIDTH ]; then
    PAD_NEED=$(( TARGET_LINE_WIDTH - VISUAL_WIDTH ))
    PAD_STR=$(printf "%${PAD_NEED}s" " ")
  else
    PAD_STR=" "
  fi

  # 3. 输出完美右对齐的终端行
  if sh -c "$CMD" >/dev/null 2>&1; then
    printf "  ${GREEN}✔${NC}  %s%s [ ${GREEN}PASS${NC} ]\n" "$DESC" "$PAD_STR"
    printf "[PASS] %-50s\n" "$DESC" >> "$REPORT_SUM"
  else
    PASS=0
    printf "  ${RED}✘${NC}  %s%s [ ${RED}FAIL${NC} ]\n" "$DESC" "$PAD_STR"
    printf "[FAIL] %-50s\n" "$DESC" >> "$REPORT_SUM"
  fi
}

info "开始评估各项底层隔离单元与网络路由链的健康度指数..."
check "Docker 核心组件可用性断言" "docker version"
check "Containerd 后台守护生存断言" "rc-service containerd status | grep -q 'status: started' || pgrep containerd"
check "Docker Daemon 守护生存断言" "rc-service docker status | grep -q 'status: started' || pgrep dockerd"
check "Open-VM-Tools 宿主同步连接断言" "rc-service open-vm-tools status | grep -q 'status: started' || pgrep vmtoolsd"
check "Git 开发辅助组件工具链断言" "git --version"
check "Curl 网络高阶请求工具链断言" "curl --version"
check "Iptables 流量网桥路由拦截断言" "[ \"\$(sysctl -n net.bridge.bridge-nf-call-iptables 2>/dev/null)\" = 1 ]"
check "Ip6tables 广域网桥路由拦截断言" "[ \"\$(sysctl -n net.bridge.bridge-nf-call-ip6tables 2>/dev/null)\" = 1 ]"
check "Docker 容器沙箱冷启动连通性测试" "docker run --rm hello-world"
check "钉钉磁盘核心监控脚本可执行鉴权" "[ -x $TARGET_BIN_PATH ]"

# 混合多构型下的 Compose 断言对齐
if docker compose version >/dev/null 2>&1; then
  DESC_COMPOSE="Docker Compose v2 编排引擎断言"
  BYTES=$(printf "%s" "$DESC_COMPOSE" | wc -c); CHARS=$(printf "%s" "$DESC_COMPOSE" | wc -m); W=$(( (BYTES + CHARS) / 2 ))
  PAD_STR=$(printf "%$(( 50 - W ))s" " ")
  printf "  ${GREEN}✔${NC}  %s%s [ ${GREEN}PASS${NC} ]\n" "$DESC_COMPOSE" "$PAD_STR"
  echo "[PASS] Docker Compose v2 available" >> "$REPORT_SUM"
elif docker-compose version >/dev/null 2>&1; then
  DESC_COMPOSE="Docker Compose v1 编排引擎断言"
  BYTES=$(printf "%s" "$DESC_COMPOSE" | wc -c); CHARS=$(printf "%s" "$DESC_COMPOSE" | wc -m); W=$(( (BYTES + CHARS) / 2 ))
  PAD_STR=$(printf "%$(( 50 - W ))s" " ")
  printf "  ${GREEN}✔${NC}  %s%s [ ${GREEN}PASS${NC} ]\n" "$DESC_COMPOSE" "$PAD_STR"
  echo "[PASS] Docker Compose v1 available" >> "$REPORT_SUM"
else
  PASS=0
  DESC_COMPOSE="Docker Compose 编排引擎断言"
  BYTES=$(printf "%s" "$DESC_COMPOSE" | wc -c); CHARS=$(printf "%s" "$DESC_COMPOSE" | wc -m); W=$(( (BYTES + CHARS) / 2 ))
  PAD_STR=$(printf "%$(( 50 - W ))s" " ")
  printf "  ${RED}✘${NC}  %s%s [ ${RED}FAIL${NC} ]\n" "$DESC_COMPOSE" "$PAD_STR"
  echo "[FAIL] Compose missing" >> "$REPORT_SUM"
fi

# 混合多构型下的加速器断言对齐
DESC_MIRROR="Registry Mirrors 容器加速器内存挂载"
BYTES=$(printf "%s" "$DESC_MIRROR" | wc -c); CHARS=$(printf "%s" "$DESC_MIRROR" | wc -m); W=$(( (BYTES + CHARS) / 2 ))
PAD_STR=$(printf "%$(( 50 - W ))s" " ")
if docker info 2>/dev/null | grep -A20 "Registry Mirrors" | grep -E 'https?://' >/dev/null 2>&1; then
  printf "  ${GREEN}✔${NC}  %s%s [ ${GREEN}PASS${NC} ]\n" "$DESC_MIRROR" "$PAD_STR"
  echo "[PASS] Registry mirrors configured" >> "$REPORT_SUM"
else
  printf "  ${YELLOW}▲${NC}  %s%s [ ${YELLOW}WARN${NC} ]\n" "$DESC_MIRROR" "$PAD_STR"
  echo "[WARN] No registry mirrors detected" >> "$REPORT_SUM"
fi

echo "" >> "$REPORT_SUM"
printf "\n"
if [ $PASS -eq 1 ]; then
  printf "${GREEN}======================================================================${NC}\n"
  printf "${BOLD}${GREEN}  🎉 恭喜！全大盘各项环境技术指标顺利通过，基础架构部署完毕！${NC}\n"
  printf "${GREEN}======================================================================${NC}\n"
  echo "[SUMMARY] ALL CHECKS PASSED SUCCESSFULLY" >> "$REPORT_SUM"
  info "完整大盘书面体检报告已生成至: $REPORT_SUM"
  printf "\n"
else
  printf "${RED}======================================================================${NC}\n"
  printf "${BOLD}${RED}  ⚠️ 警告：大盘检测中发现部分核心指标异常，请根据上文进行追溯核验。${NC}\n"
  printf "${RED}======================================================================${NC}\n"
  echo "[SUMMARY] EXTRACTION RUN COMPLETED WITH ENVIROMENTAL FAULTS" >> "$REPORT_SUM"
  info "不合格细节明细参见技术分析报告: $REPORT_SUM"
  printf "\n"
  exit 2
fi
