services:
  mosdns:
    image: irinesistiana/mosdns:latest
    container_name: mosdns
    ports:
      - "5335:53/udp"
      - "5335:53/tcp"
    volumes:
      # MosDNS 主配置目录：
      # 容器内 /etc/mosdns/config_custom.yaml
      # 容器内 /etc/mosdns/dat_exec.yaml
      # 容器内 /etc/mosdns/rule/nocache.txt
      - /root/mosdns/config:/etc/mosdns

      # rules-dat 规则文件目录：
      # 供 local_hosts 使用 /etc/mosdns/rules-dat/hosts.txt
      - /root/mosdns/rules-dat:/etc/mosdns/rules-dat

      # 兼容 dat_exec.yaml 内部引用：
      # /var/mosdns/geoip_private.txt
      # /var/mosdns/geosite_gfw.txt
      # /var/mosdns/geosite_cn.txt 等
      - /root/mosdns/rules-dat:/var/mosdns

    command: mosdns start -c /etc/mosdns/config_custom.yaml
    restart: unless-stopped
