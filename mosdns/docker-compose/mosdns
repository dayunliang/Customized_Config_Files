services:
  mosdns:
    image: irinesistiana/mosdns:latest
    container_name: mosdns
    ports:
      - "5335:53/udp"
      - "5335:53/tcp"
    volumes:
      - /root/mosdns/config:/etc/mosdns
      - /root/mosdns/rules-dat:/var/mosdns
    entrypoint: |
      /bin/sh -c "\
      : > /var/log/mosdns.log && \
      exec mosdns start -c /etc/mosdns/config_custom.yaml\
      "
    restart: unless-stopped
