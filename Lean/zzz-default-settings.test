#!/bin/sh
#
# zzz-default-settings (Beverly)
# 放置于：package/lean/default-settings/files/zzz-default-settings
#

# =============================================================================
# 1. 设置 LuCI 界面语言与默认主题
# =============================================================================
uci set luci.main.lang='zh_cn'
uci set luci.main.mediaurlbase='/luci-static/bootstrap'
uci commit luci

# =============================================================================
# 2. 设置系统时区、主机名和 NTP 服务器
# =============================================================================
uci -q batch <<-EOF
  set system.@system[0].timezone='CST-8'
  set system.@system[0].zonename='Asia/Shanghai'
  set system.@system[0].hostname='Beverly.2nd.Router'
  delete system.ntp.server[cite: 1]
  add_list system.ntp.server='ntp1.aliyun.com'[cite: 1]
  add_list system.ntp.server='ntp.tencent.com'[cite: 1]
  add_list system.ntp.server='ntp.ntsc.ac.cn'[cite: 1]
  add_list system.ntp.server='time.ustc.edu.cn'[cite: 1]
EOF
uci commit system[cite: 1]

# =============================================================================
# 3. 基础功能设置 (挂载、菜单重命名、源优化)
# =============================================================================
uci set fstab.@global[0].anon_mount=1[cite: 1]
uci commit fstab[cite: 1]

# 清理 LuCI 状态页面[cite: 1]
rm -f /usr/lib/lua/luci/view/admin_status/index/{mwan,upnp,ddns,minidlna}.htm[cite: 1]

# 重命名 “Services” 菜单为 “NAS”[cite: 1]
for ctl in aria2 hd_idle samba samba4 minidlna transmission mjpg-streamer p910nd usb_printer xunlei; do
  [ -f "/usr/lib/lua/luci/controller/${ctl}.lua" ] && \
    sed -i 's/"services"/"nas"/g' /usr/lib/lua/luci/controller/${ctl}.lua[cite: 1]
done
for view in overview_status minidlna_status; do
  [ -f "/usr/lib/lua/luci/view/${view}.htm" ] && \
    sed -i 's/services/nas/g' /usr/lib/lua/luci/view/${view}.htm[cite: 1]
done

# 更换 OPKG 源[cite: 1]
sed -i 's|https://downloads.openwrt.org|https://mirrors.aliyun.com/openwrt|g' /etc/opkg/distfeeds.conf[cite: 1]
sed -i '/smpackage/s/^/#/'       /etc/opkg/distfeeds.conf[cite: 1]
sed -i '/kenzo/s/^/#/'           /etc/opkg/distfeeds.conf[cite: 1]
sed -i '/small/s/^/#/'           /etc/opkg/distfeeds.conf[cite: 1]
sed -i '/openwrt_istore/s|^|#|'  /etc/opkg/distfeeds.conf[cite: 1]
sed -i '/check_signature/s/^/#/' /etc/opkg.conf[cite: 1]

# 重置 root 密码[cite: 1]
sed -i 's#root::0:0:99999:7:::#root:$1$V4UetPzk$CYXluq4wUazHjmCDBCqXF.:0:0:99999:7:::#g' /etc/shadow[cite: 1]

# 优化 Dnsmasq 与无线接口[cite: 1]
sed -i '/log-facility/d' /etc/dnsmasq.conf[cite: 1]
echo "log-facility=/dev/null" >> /etc/dnsmasq.conf[cite: 1]
sed -i '/option disabled/d' /etc/config/wireless[cite: 1]
sed -i '/set wireless.radio${devidx}.disabled/d' /lib/wifi/mac80211.sh[cite: 1]

# 自定义固件版本[cite: 1]
sed -i '/DISTRIB_REVISION/d'    /etc/openwrt_release[cite: 1]
echo "DISTRIB_REVISION='366.11.07'" >> /etc/openwrt_release[cite: 1]
sed -i '/DISTRIB_DESCRIPTION/d' /etc/openwrt_release[cite: 1]
echo "DISTRIB_DESCRIPTION='OpenWrt '" >> /etc/openwrt_release[cite: 1]

# =============================================================================
# 4. 网络与 VLAN 静态设置
# =============================================================================
# 清理旧架构字段[cite: 1]
uci delete network.lan.ifname 2>/dev/null || true
uci delete network.lan.type   2>/dev/null || true
uci delete network.lan.device 2>/dev/null || true
uci delete network.wan.ifname 2>/dev/null || true
uci delete network.wan.type   2>/dev/null || true
uci delete network.wan.device 2>/dev/null || true

# LAN 接口 (旁路由/网关服务器模式)[cite: 1]
uci set network.lan.proto='static'[cite: 1]
uci set network.lan.device='eth0'[cite: 1]
uci set network.lan.ipaddr='192.168.122.144'[cite: 1]
uci set network.lan.netmask='255.255.255.0'[cite: 1]
uci set dhcp.lan=dhcp[cite: 1]
uci set dhcp.lan.interface='lan'[cite: 1]
uci set dhcp.lan.ignore='1'[cite: 1]
uci set dhcp.lan.dhcpv6='disabled'[cite: 1]
uci set dhcp.lan.ra='disabled'[cite: 1]

# WAN 接口 (管理口)[cite: 1]
uci set network.wan.proto='static'[cite: 1]
uci set network.wan.device='eth1'[cite: 1]
uci set network.wan.ipaddr='192.168.12.144'[cite: 1]
uci set network.wan.netmask='255.255.255.0'[cite: 1]
uci set network.wan.gateway='192.168.12.253'[cite: 1]
uci set network.wan.dns='192.168.12.10 192.168.12.11'[cite: 1]

# VLAN 设备创建函数[cite: 1]
ensure_vlan_dev() {
  _dev="$1"; _vid="$2"; _sec=""
  for s in $(uci -q show network | grep "=device" | cut -d= -f1); do
    [ "$(uci -q get ${s}.name 2>/dev/null)" = "${_dev}" ] && _sec="$s" && break
  done
  if [ -z "$_sec" ]; then uci add network device >/dev/null; _sec="network.@device[-1]"; fi
  uci set ${_sec}.name="${_dev}"; uci set ${_sec}.type="8021q"; uci set ${_sec}.ifname="eth1"; uci set ${_sec}.vid="${_vid}"
}

ensure_vlan_dev "eth1.50" "50"[cite: 1]
ensure_vlan_dev "eth1.80" "80"[cite: 1]
ensure_vlan_dev "eth1.90" "90"[cite: 1]

# VLAN 接口静态 IP[cite: 1]
for v in 50 80 90; do
  uci set network.VLAN$v='interface'[cite: 1]
  uci set network.VLAN$v.proto='static'[cite: 1]
  uci set network.VLAN$v.device="eth1.$v"[cite: 1]
  uci set network.VLAN$v.ipaddr="192.168.$v.144"[cite: 1]
  uci set network.VLAN$v.netmask='255.255.255.0'[cite: 1]
done

# 彻底禁用 IPv6[cite: 1]
uci delete network.wan6 2>/dev/null[cite: 1]
uci delete dhcp.wan6    2>/dev/null[cite: 1]
grep -q 'disable_ipv6' /etc/sysctl.conf || cat << 'EOF' >> /etc/sysctl.conf
net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
net.ipv6.conf.lo.disable_ipv6 = 1
EOF
/etc/init.d/odhcpd disable 2>/dev/null[cite: 1]

uci commit network[cite: 1]
uci commit dhcp[cite: 1]

# =============================================================================
# 5. 极致安全防火墙配置 (核心修改)
# =============================================================================
# 5.1 区域基础策略[cite: 1]
# 锁定 LAN 侧 Input (拒绝管理)，保留 Forward (允许翻墙流量)[cite: 1]
uci set firewall.@zone[0].input='REJECT'[cite: 1]
uci set firewall.@zone[0].forward='ACCEPT'[cite: 1]

# 将 VLAN 接口归入 LAN Zone[cite: 1]
for v in VLAN50 VLAN80 VLAN90; do
  _zsec=""
  for s in $(uci -q show firewall | grep "=zone" | cut -d= -f1); do
    [ "$(uci -q get ${s}.name 2>/dev/null)" = "lan" ] && _zsec="$s" && break
  done
  [ -n "$_zsec" ] && uci add_list ${_zsec}.network="$v"[cite: 1]
done

# 5.2 业务放行规则[cite: 1]
# 允许 DNS 服务 (53 端口) - 业务必需[cite: 1]
uci add firewall rule >/dev/null
uci set firewall.@rule[-1].name='Allow-DNS-Input'
uci set firewall.@rule[-1].src='lan'
uci set firewall.@rule[-1].dest_port='53'
uci set firewall.@rule[-1].proto='tcp udp'
uci set firewall.@rule[-1].target='ACCEPT'

# 允许 mDNS (5353 端口) - Avahi 必需[cite: 1]
uci add firewall rule >/dev/null
uci set firewall.@rule[-1].name='Allow-mDNS-Input'
uci set firewall.@rule[-1].src='lan'
uci set firewall.@rule[-1].dest_port='5353'
uci set firewall.@rule[-1].proto='udp'
uci set firewall.@rule[-1].target='ACCEPT'

# 5.3 WAN 侧管理白名单 (唯一的钥匙)[cite: 1]
uci add firewall rule >/dev/null
uci set firewall.@rule[-1].name='Allow-Admin-From-WAN-Secure'
uci set firewall.@rule[-1].src='wan'
uci set firewall.@rule[-1].src_ip='192.168.12.2 10.10.10.2 10.10.10.3 10.10.10.4 10.10.10.5'
uci set firewall.@rule[-1].proto='tcp'
uci set firewall.@rule[-1].dest_port='22 80 443'
uci set firewall.@rule[-1].target='ACCEPT'

# 5.4 WireGuard 基础放行[cite: 1]
uci -q delete firewall.Allow_WG_Handshake
uci set firewall.Allow_WG_Handshake='rule'
uci set firewall.Allow_WG_Handshake.name='Allow-WireGuard-Handshake'
uci set firewall.Allow_WG_Handshake.src='wan'
uci set firewall.Allow_WG_Handshake.proto='udp'
uci set firewall.Allow_WG_Handshake.dest_port='58058'
uci set firewall.Allow_WG_Handshake.target='ACCEPT'

# 5.5 WireGuard Zone 与转发逻辑[cite: 1]
# 创建 wg0 zone[cite: 1]
uci add firewall zone >/dev/null
uci set firewall.@zone[-1].name='wg0'
uci set firewall.@zone[-1].input='ACCEPT'
uci set firewall.@zone[-1].output='ACCEPT'
uci set firewall.@zone[-1].forward='ACCEPT'
uci add_list firewall.@zone[-1].network='wg0'[cite: 1]

# 转发去重添加函数[cite: 1]
has_fwd(){ for f in $(uci -q show firewall | grep "=forwarding" | cut -d= -f1); do
  [ "$(uci -q get ${f}.src)" = "$1" ] && [ "$(uci -q get ${f}.dest)" = "$2" ] && return 0; done; return 1; }

has_fwd lan wg0 || { uci add firewall forwarding >/dev/null; uci set firewall.@forwarding[-1].src='lan'; uci set firewall.@forwarding[-1].dest='wg0'; }[cite: 1]
has_fwd wg0 lan || { uci add firewall forwarding >/dev/null; uci set firewall.@forwarding[-1].src='wg0'; uci set firewall.@forwarding[-1].dest='lan'; }[cite: 1]
has_fwd wg0 wan || { uci add firewall forwarding >/dev/null; uci set firewall.@forwarding[-1].src='wg0'; uci set firewall.@forwarding[-1].dest='wan'; }[cite: 1]
has_fwd wan wg0 || { uci add firewall forwarding >/dev/null; uci set firewall.@forwarding[-1].src='wan'; uci set firewall.@forwarding[-1].dest='wg0'; }[cite: 1]

uci commit firewall[cite: 1]

# =============================================================================
# 6. WireGuard 接口与对端 Peer 配置 (Beverly 侧)
# =============================================================================
uci -q batch << 'EOF'
  set network.wg0='interface'[cite: 1]
  set network.wg0.proto='wireguard'[cite: 1]
  set network.wg0.private_key='__WG_PRIVKEY__'[cite: 1]
  set network.wg0.listen_port='58058'[cite: 1]
  add_list network.wg0.addresses='10.0.0.1/24'[cite: 1]
  set network.wg0.mtu='1420'[cite: 1]
  delete network.@wireguard_wg0[0][cite: 1]
  add network wireguard_wg0[cite: 1]
  set network.@wireguard_wg0[-1].description='Riviera'[cite: 1]
  set network.@wireguard_wg0[-1].public_key='4kY/LleOD1EsJ0tEqQ0SdgAa3BGeDYwv06QltDC9Kko='[cite: 1]
  set network.@wireguard_wg0[-1].persistent_keepalive='25'[cite: 1]
  set network.@wireguard_wg0[-1].route_allowed_ips='1'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.0.0.2/32'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.29.2.0/24'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.29.80.0/24'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.29.90.0/24'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.29.122.0/24'[cite: 1]
  add_list network.@wireguard_wg0[-1].allowed_ips='10.10.20.0/24'[cite: 1]
EOF
uci commit network[cite: 1]

# =============================================================================
# 7. 系统服务开启 (Avahi, Dropbear, PassWall)
# =============================================================================
# Dropbear 监听所有接口 (靠防火墙控制白名单)[cite: 1]
uci delete dropbear.@dropbear[0].Interface 2>/dev/null[cite: 1]
uci commit dropbear[cite: 1]

# Avahi (mDNS) 启动[cite: 1]
[ -x /etc/init.d/dbus ] && /etc/init.d/dbus enable && /etc/init.d/dbus restart[cite: 1]
[ -x /etc/init.d/avahi-daemon ] && /etc/init.d/avahi-daemon enable && /etc/init.d/avahi-daemon restart[cite: 1]

# PassWall2 启动[cite: 1]
[ -x /etc/init.d/passwall2 ] && /etc/init.d/passwall2 start[cite: 1]

# =============================================================================
# 8. 脚本自删除
# =============================================================================
rm -f /etc/uci-defaults/zzz-default-settings[cite: 1]
exit 0
