#!/bin/bash
# ===========================================================================
# Lean OpenWrt 定制文件一键部署脚本 【正式纯净版】
# ---------------------------------------------------------------------------
# 本脚本旨在实现 OpenWrt 源码树的“非侵入式、自动化、幂等性”配置部署。
# 
# 核心工作流：
#   [1-2] 前置检查：验证 Bash 环境，并在缺失源码时提供交互式自动 Clone。
#   [3-5] 环境准备：创建防碰撞临时目录，使用 Sparse Checkout 精准拉取配置仓库。
#   [6-7] 核心函数：声明自动备份、站点匹配（站点优先，默认兜底）、以及脏余代码清理逻辑。
#   [8-10] 依赖补齐：补充缺失的 Luci 源，编译 po2lmo 工具，并拉取第三方主题与插件。
#   [11] 文件部署：将配置写入源码树（站点优先，私密无感覆盖）。
#   [12-14] 收尾固化：清理环境、固化 .config、预下载源码包并打印最终部署摘要。
#
# 安全机制：
#   - set -e：开启严格模式，任何非预期的命令失败都会立即终止脚本，防止错误雪崩。
#   - trap：捕捉脚本退出信号（无论正常结束还是意外崩溃），确保临时目录被安全销毁。
#   - 智能备份：覆盖任何已有文件前，会自动生成 .bak.时间戳 文件。
# ---------------------------------------------------------------------------
# 作者：https://github.com/dayunliang
# 更新：移除交互式密钥注入，实现基于多站点私有文件的全自动免干预部署。
# ===========================================================================

set -e  # 【安全护栏】任何命令出错立即退出（避免错误链式传播）

# ===========================================================================
# [1] 环境与前置检查
# ===========================================================================
# 目的：确保脚本在 bash 下执行，因为脚本使用了数组 (declare -a) 等 Bash 专属特性。
if [ -z "$BASH_VERSION" ]; then
    echo "❗ 必须在 bash 环境下执行此脚本，sh 环境不支持！"
    exit 1
fi

# ===========================================================================
# [2] OpenWrt 源码目录检测与克隆
# ===========================================================================
# 判据：当前目录下是否存在 scripts/feeds 文件和 package 目录。
# 若不满足，则触发交互式引导，允许用户直接从 GitHub 克隆全新的源码树。

# Spinner 加载动画函数：在后台静默删除或克隆时，提供视觉反馈缓解焦虑
show_spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while ps -p $pid > /dev/null 2>&1; do
        local temp=${spinstr#?}
        printf " [%c] 正在清空目录..." "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\r%-40s\r" " "   # 清空整行避免残留视觉干扰
    done
}

if [ ! -f "./scripts/feeds" ] || [ ! -d "./package" ]; then
    echo "🔍 未检测到 OpenWrt 源码根目录。"
    read -p "是否自动 clone OpenWrt 仓库并进入？(y/N): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # 读取远端仓库地址与本地目标文件夹名（带默认值兜底）
        read -p "请输入 OpenWrt 仓库 URL (默认: https://github.com/coolsnowwolf/lede.git): " repo_url
        repo_url=${repo_url:-https://github.com/coolsnowwolf/lede.git}

        read -p "请输入目标目录名 (默认: lede): " target_dir
        target_dir=${target_dir:-lede}

        # 目标目录已存在时的防御逻辑
        if [ -d "$target_dir" ]; then
            echo "⚠️ 目录 $target_dir 已存在，进入该目录..."
            cd "$target_dir"

            if [ -z "$(ls -A .)" ]; then
                echo "🌐 目录为空，正在克隆 $repo_url ..."
                git clone --depth=1 "$repo_url" . || { echo "❌ 克隆失败"; exit 1; }
            else
                read -p "⚠️ 当前目录非空，是否清空后再克隆？(y/N): " clear_confirm
                if [[ "$clear_confirm" =~ ^[Yy]$ ]]; then
                    (rm -rf ./* ./.??* ) & # 放入后台执行以配合 spinner
                    pid=$!
                    show_spinner $pid
                    wait $pid
                    echo "✅ 目录已清空"
                    echo "🌐 开始克隆 $repo_url ..."
                    git clone --depth=1 "$repo_url" . || { echo "❌ 克隆失败"; exit 1; }
                else
                    # 拒绝清空时，最后一次检查当前目录是否已经是有效的源码树
                    if [ ! -f "./scripts/feeds" ] || [ ! -d "./package" ]; then
                        echo "❌ 当前目录不是有效的 OpenWrt 源码目录，无法继续"
                        exit 1
                    fi
                    echo "➡️ 跳过 git clone，继续执行后续步骤..."
                fi
            fi
        else
            echo "🌐 正在克隆 $repo_url 到 $target_dir ..."
            git clone --depth=1 "$repo_url" "$target_dir" || { echo "❌ 克隆失败"; exit 1; }
            cd "$target_dir"
        fi
        echo "✅ 已进入源码目录：$(pwd)"
    else
        echo "❌ 请先手动下载源码再运行本脚本"
        echo "示例："
        echo "  git clone https://github.com/coolsnowwolf/lede.git"
        echo "  cd lede"
        echo "  bash $0"
        exit 1
    fi
fi

# ===========================================================================
# [3] 全局变量初始化与清理机制
# ===========================================================================
# 1. 公开配置仓库（保持 HTTPS 格式，拉取不敏感的通用配置）
REPO_PUBLIC_URL="https://github.com/dayunliang/Customized_Config_Files.git"

# 2. 私人配置仓库（使用 SSH 格式，拉取高度敏感的私密配置）
REPO_PRIVATE_URL="git@github.com:dayunliang/private_config.git"

SPARSE_DIR="Lean"                                                    # 两个仓库里需要拉取的子目录（假设结构一致）
TMP_DIR=$(mktemp -d)                                                 # 创建随机临时目录，避免 tmux 多开碰撞
TS=$(date +%Y%m%d-%H%M%S)                                            # 全局时间戳，用于文件备份命名
declare -a BACKUP_LIST                                               # 全局数组，负责收集备份文件路径

# Trap 垃圾回收机制
cleanup() {
    if [ -n "$TMP_DIR" ] && [ -d "$TMP_DIR" ]; then
        echo "🧹 触发退出清理：销毁临时目录 $TMP_DIR"
        rm -rf "$TMP_DIR"
    fi
}
trap cleanup EXIT

# ===========================================================================
# [4] 远程配置仓库双向克隆与合并 (完美单层 Lean 版)
# ===========================================================================
echo "➡️ [Step 1] 开始双仓就地原子合并流程..."

# --- 4.1 直接克隆公开仓库到临时主目录 ---
echo "🌐 1. 正在克隆公开基础配置..."
if ! git clone --depth=1 --filter=blob:none --sparse "$REPO_PUBLIC_URL" "$TMP_DIR"; then
    echo "❌ 克隆公开仓库失败"
    exit 1
fi
# 此时配置会精准落盘到 ${TMP_DIR}/Lean/
cd "$TMP_DIR" && git sparse-checkout set "$SPARSE_DIR" && cd - >/dev/null


# --- 4.2 将私人仓库克隆到独立的临时过渡目录 ---
TMP_PRV="${TMP_DIR}/private_tmp"
echo "🔒 2. 正在通过 SSH 拉取私人敏感配置..."
mkdir -p ~/.ssh && ssh-keyscan -t ed25519 github.com >> ~/.ssh/known_hosts 2>/dev/null

if ! git clone --depth=1 --filter=blob:none --sparse "$REPO_PRIVATE_URL" "$TMP_PRV"; then
    echo "❌ 克隆私人仓库失败"
    exit 1
fi
cd "$TMP_PRV" && git sparse-checkout set "$SPARSE_DIR" && cd - >/dev/null


# --- 4.3 核心原子覆盖与痕迹擦除 ---
echo "🔀 3. 正在将私人配置就地覆盖到 ./Lean 并强力去重..."
if [ -d "${TMP_PRV}/Lean" ]; then
    # 将私有 Lean 内的所有内容覆盖到主 Lean 内
    cp -r "${TMP_PRV}/Lean/." "${TMP_DIR}/Lean/"
fi

# 瞬间过河拆桥，擦除私人仓库在本地留下的临时痕迹
rm -rf "$TMP_PRV"

echo "✅ 双仓配置单层合并完成！当前纯净目录已锁定。"

# ===========================================================================
# [5] 目标编译版本选择
# ===========================================================================
echo
echo "➡️ [Step 2] 请选择本次要部署的编译配置站点："
echo " 1) Beverly"
echo " 2) Riviera"
echo " 3) DOITCHINA"
read -p "请输入数字 (1-3): " compile_choice

case "$compile_choice" in
  1) COMPILE_NAME="Beverly" ;;
  2) COMPILE_NAME="Riviera" ;;
  3) COMPILE_NAME="DOITCHINA" ;;
  *) echo "❌ 无效选择：$compile_choice"; exit 1 ;;
esac
echo "✅ 已锁定编译目标站：$COMPILE_NAME"
echo

# ===========================================================================
# [6] 核心部署与统计函数声明
# ===========================================================================
__DEPLOY_HITS=""
__DEPLOY_SKIPS=""
__hit()  { __DEPLOY_HITS="${__DEPLOY_HITS}${1}\n"; }
__skip() { __DEPLOY_SKIPS="${__DEPLOY_SKIPS}${1}\n"; }

# 核心功能：安全复制 (带备份)
safe_cp() {
  src="$1"
  dst="$2"
  if [ -f "$dst" ]; then
    backup_name="$dst.bak.$TS"
    cp -v "$dst" "$backup_name"
    BACKUP_LIST+=("$backup_name")
  fi
  mkdir -p "$(dirname "$dst")"
  cp -vf "$src" "$dst"
}

SRC_ROOT="${TMP_DIR}/Lean/files"   # 你的自定义 Overlay 目录
DST_ROOT="./files"                 # OpenWrt 原生 Overlay 目录

# 核心功能：常规文件部署 (带站点兜底逻辑)
deploy_file() {
  rel="$1"
  mode="${2:-644}"
  site_src="${SRC_ROOT}/${rel}.${COMPILE_NAME}"
  def_src="${SRC_ROOT}/${rel}"
  dst="${DST_ROOT}/${rel}"

  if [ -f "${site_src}" ]; then
    echo "  [DEPLOY] ${site_src} -> ${dst}"
    safe_cp "${site_src}" "${dst}"
    chmod "${mode}" "${dst}" || true   # 权限赋予失败不阻断流程
    __hit "${rel} (site=${COMPILE_NAME})"
  elif [ -f "${def_src}" ]; then
    echo "  [DEPLOY] ${def_src} -> ${dst}"
    safe_cp "${def_src}" "${dst}"
    chmod "${mode}" "${dst}" || true
    __hit "${rel} (default)"
  else
    echo "  [SKIP_OK] ${rel} (未提供配置，安全跳过)"
    __skip "${rel}"
  fi
  return 0
}

# 核心功能：根级文件部署 (针对 feeds.conf, .config 等特殊位置)
deploy_root() {
  name="$1"
  dst="$2"
  mode="${3:-644}"
  site_src="${TMP_DIR}/Lean/${name}.${COMPILE_NAME}"
  def_src="${TMP_DIR}/Lean/${name}"

  if [ -f "${site_src}" ]; then
    echo "  [DEPLOY] ${site_src} -> ${dst}"
    safe_cp "${site_src}" "${dst}"
    chmod "${mode}" "${dst}" || true
    __hit "${name} (site=${COMPILE_NAME})"
  elif [ -f "${def_src}" ]; then
    echo "  [DEPLOY] ${def_src} -> ${dst}"
    safe_cp "${def_src}" "${dst}"
    chmod "${mode}" "${dst}" || true
    __hit "${name} (default)"
  else
    echo "  [SKIP_OK] root ${name} (未提供配置，安全跳过)"
    __skip "${name}"
  fi
  return 0
}

# 汇总打印函数
deploy_summary() {
  printf '\n📊 [最终部署清单摘要] Profile = %s\n' "${COMPILE_NAME}"
  if [ -n "${__DEPLOY_HITS}" ]; then
    printf '✅ [成功落盘]\n%b' "${__DEPLOY_HITS}"
  else
    printf '✅ [成功落盘]\n(无)\n'
  fi

  if [ -n "${__DEPLOY_SKIPS}" ]; then
    printf '⏭️  [安全跳过]\n%b' "${__DEPLOY_SKIPS}"
  else
    printf '⏭️  [安全跳过]\n(无)\n'
  fi
}

# ===========================================================================
# [7] 编译前环境修补函数声明 (AdvancedPlus 恶意代码清理)
# ===========================================================================
# 背景：防止 luci-app-advancedplus 污染宿主机的 /etc/profile，导致 SSH 报错
clean_advancedplus_zsh_autostart() {
    echo "=== 🧹 [Clean] 开始清理 luci-app-advancedplus 的非法 zsh 写入逻辑 ==="
    ADVANCEDPLUS_INIT="package/lean/luci-app-advancedplus/root/etc/init.d/advancedplus"
    ADVANCEDPLUS_INIT_BAK="package/lean/luci-app-advancedplus/root/etc/init.d/advancedplus.bak"

    if [ -f "$ADVANCEDPLUS_INIT" ]; then
        if grep -q "/usr/bin/zsh" "$ADVANCEDPLUS_INIT" 2>/dev/null; then
            echo "  发现 zsh 污染代码，正在斩断：$ADVANCEDPLUS_INIT"
            sed -i "\#echo '/usr/bin/zsh'[[:space:]]*>>[[:space:]]*/etc/profile#d" "$ADVANCEDPLUS_INIT"
            sed -i "\#/usr/bin/zsh.*>>[[:space:]]*/etc/profile#d" "$ADVANCEDPLUS_INIT"
        else
            echo "  未发现 zsh 写入逻辑，该版本安全。"
        fi
    else
        echo "  未找到目标 init 脚本，跳过。"
    fi

    [ -f "$ADVANCEDPLUS_INIT_BAK" ] && rm -f "$ADVANCEDPLUS_INIT_BAK"

    # 清理遗留构建缓存，防止旧版残留
    rm -rf build_dir/target-x86_64_musl/luci-app-advancedplus 2>/dev/null || true
    rm -f build_dir/target-x86_64_musl/root-x86/etc/init.d/advancedplus 2>/dev/null || true
    rm -f build_dir/target-x86_64_musl/root-x86/etc/rc.d/*advancedplus 2>/dev/null || true
    rm -f staging_dir/target-x86_64_musl/root-x86/etc/init.d/advancedplus 2>/dev/null || true

    echo "=== 🧹 [Clean] 清理完成 ==="
}

# ===========================================================================
# [8] 检查与安装基础 feeds (luci-base)
# ===========================================================================

deploy_root "feeds.conf.default"     "./feeds.conf.default"                               "644"

echo "➡️ [Step 3] 验证环境依赖与 Feeds..."
if ! grep -qE '^src-git[[:space:]]+luci[[:space:]]+' feeds.conf.default; then
    echo "  ⚠️ feeds.conf.default 缺少 luci 源，自动追加..."
    echo "src-git luci https://github.com/coolsnowwolf/luci" >> feeds.conf.default
fi

./scripts/feeds update luci
./scripts/feeds install luci-base

# ===========================================================================
# [9] 编译基础工具 (po2lmo)
# ===========================================================================
echo "🛠️ 正在预编译 po2lmo 翻译工具 (解决 UI 编译报错问题)..."
make package/feeds/luci/luci-base/host/compile V=s


# ===========================================================================
# [10] 全量安装 feeds 与第三方插件拉取
# ===========================================================================
echo "🛠️ 正在执行全量 feeds update & install..."
./scripts/feeds clean
./scripts/feeds update -a
./scripts/feeds install -a

echo "🌈 正在拉取第三方主题与应用库 (kucat / advancedplus)..."
mkdir -p package/lean
rm -rf package/lean/luci-app-kucat-config 
rm -rf package/lean/luci-theme-kucat  
rm -rf package/lean/luci-app-advancedplus 
git clone https://github.com/sirpdboy/luci-theme-kucat.git package/lean/luci-theme-kucat
git clone https://github.com/sirpdboy/luci-app-kucat-config.git package/lean/luci-app-kucat-config
git clone https://github.com/sirpdboy/luci-app-advancedplus.git package/lean/luci-app-advancedplus

clean_advancedplus_zsh_autostart # 首次清理恶意代码

# ===========================================================================
# [11] 执行配置文件部署
# ===========================================================================
echo
echo "➡️ [Step 4] 开始向源码树投递 [$COMPILE_NAME] 的所有配置文件..."

# 11.1 部署代码仓库根级配置文件
deploy_root "config"                 "./.config"                                          "644"
deploy_root "zzz-default-settings"   "./package/lean/default-settings/files/zzz-default-settings" "755"
deploy_root "remove_conflict.sh"     "./remove_conflict.sh"                               "755"

# 11.2 部署 Overlay 文件系统 (路由/VPN/Clash)
deploy_file "usr/bin/back-route-checkenv.sh"                          "755"
deploy_file "usr/bin/back-route-complete.sh"                          "755"
deploy_file "usr/bin/back-route-cron.sh"                              "755"
deploy_file "etc/config/openclash"                                    "644"
deploy_file "etc/openclash/custom/openclash_custom_rules.list"        "644"
deploy_file "usr/share/openclash/res/rule_providers.list"             "644"
deploy_file "etc/openclash/dns_enable_false.sh"                       "755"
deploy_file "usr/share/openclash/yml_proxys_set.sh"                   "755"

# 独立处理 ACL4SSR 配置文件目录创建与部署
mkdir -p ./files/etc/openclash/config
cp ${TMP_DIR}/Lean/files/etc/openclash/config/OpenClash_ACL4SSR_Full_AJ_Home.yaml ./files/etc/openclash/config/OpenClash_ACL4SSR_Full_AJ_Home.yaml
chmod 644 ./files/etc/openclash/config/OpenClash_ACL4SSR_Full_AJ_Home.yaml

deploy_file "etc/config/passwall2"                                    "644"
deploy_file "usr/bin/wireguard_refresh.sh"                            "755"
deploy_file "etc/dbus-1/system.d/avahi-dbus.conf"                     "644"
deploy_file "etc/avahi/avahi-daemon.conf"                             "644"
deploy_file "etc/config/turboacc"                                     "644"
deploy_file "etc/crontabs/root"                                       "600"

# ===========================================================================
# [12] 冲突清理与 .config 固化
# ===========================================================================
echo
echo "➡️ [Step 5] 依赖梳理与冲突项筛除..."
./remove_conflict.sh
make defconfig
clean_advancedplus_zsh_autostart # defconfig 后再次防遗漏清理

# ===========================================================================
# [13] 首次构建依赖预下载
# ===========================================================================
echo
echo "➡️ [Step 6] 构建预备选项..."
read -p "🧐 是否首次构建？需要为您自动预下载 dl 源码依赖包吗？(y/N): " is_first
if [[ "$is_first" =~ ^[Yy]$ ]]; then
    echo "📥 开始预下载源码包 (可能需要较长时间)..."
    while true; do
        make download -j8 V=s
        broken=$(find dl -size -1024c)
        if [ -z "$broken" ]; then
            echo "  ✅ 下载完成，未发现损坏的碎片文件。"
            break
        else
            echo "  ⚠️ 检测到体积异常的损坏文件，正在清理并重试..."
            find dl -size -1024c -exec rm -f {} \;
        fi
    done
else
    echo "⏭️ 跳过依赖预下载。"
fi

# ===========================================================================
# [14] 执行结果汇总与清理
# ===========================================================================
deploy_summary

if [ ${#BACKUP_LIST[@]} -gt 0 ]; then
    echo "🗂️ 本次备份旧文件明细："
    for f in "${BACKUP_LIST[@]}"; do echo "  - $f"; done
else
    echo "🗂️ 目标系统纯净，本次部署未产生任何冲突覆盖及备份。"
fi

echo
echo "======================================================="
echo "📋 本次自动化部署执行摘要："
echo "  ✅ [完成] 动态拉取指定分支配置 ($SPARSE_DIR)"
echo "  ✅ [完成] 配置文件多维度覆盖与智能备份"
echo "  ✅ [完成] Feeds 依赖更新与 po2lmo 本地编译"
echo "  ✅ [完成] 自动清理恶意的 ZSH 配置注入"
echo "  ✅ [完成] 纯净无感的多站点隐私配置落盘"
echo "======================================================="
echo "🚀 恭喜！一切准备就绪！"
echo "👉 当前工作路径: $(pwd)"
echo "💡 输入以下命令启动起飞编译："
echo "   make -j$(nproc) V=s"
